{
  "site_name": "mixed-protocol-site",
  "step": 0.1,
  "real_time": true,
  "start_time_h": 12.0,
  "register_map_root": "register_maps",

  "external_models": {
    "power": {
      "base_load_w": 10000.0
    },
    "irradiance": {
      "peak": 1000.0,
      "sunrise": 6.0,
      "sunset": 18.0
    },
    "ambient_temperature": {
      "mean": 25.0,
      "amplitude": 10.0,
      "peak_hour": 15.0
    },
    "grid_frequency": {
      "nominal_hz": 50.0,
      "noise_std": 0.002,
      "drift_std": 0.0002,
      "seed": 42
    },
    "grid_voltage": {
      "nominal_v_ll": 400.0,
      "noise_std": 0.5,
      "drift_std": 0.05,
      "seed": 42
    }
  },

  "assets": [
    {
      "comment": "BESS — 100 kWh, Modbus TCP for EMS control",
      "type": "bess",
      "capacity_kwh": 100.0,
      "initial_soc": 50.0,
      "max_charge_kw": 30.0,
      "max_discharge_kw": 30.0,
      "ramp_rate_kw_per_s": 10.0,
      "protocols": [
        {
          "kind": "modbus_tcp",
          "ip": "0.0.0.0",
          "port": 55001,
          "unit_id": 1,
          "register_map": "bess_modbus.yaml"
        }
      ]
    },
    {
      "comment": "PV inverter — 20 kW rated, Modbus RTU (serial)",
      "type": "inverter",
      "rated_kw": 20.0,
      "protocols": [
        {
          "kind": "modbus_rtu",
          "port": "/tmp/dertwin_pv",
          "baudrate": 9600,
          "unit_id": 2,
          "register_map": "pv_inverter_modbus.yaml"
        }
      ]
    },
    {
      "comment": "Energy meter — PCC measurement, Modbus RTU (serial)",
      "type": "energy_meter",
      "protocols": [
        {
          "kind": "modbus_rtu",
          "port": "/tmp/dertwin_meter",
          "baudrate": 9600,
          "unit_id": 3,
          "register_map": "energy_meter_modbus.yaml"
        }
      ]
    }
  ]
}